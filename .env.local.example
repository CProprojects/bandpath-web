# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored — never commit real secrets.

# Supabase — Project Settings > Data API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — Project Settings > API Keys
# Server-only, bypasses Row Level Security. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Telegram bot — created via @BotFather, used for the "login with a code" flow
TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Public site URL — used to build the "Open BandPath" link the bot sends
# when a user logs in from inside Telegram (the /start menu's "Go to Platform"
# button).
SITE_URL=

# Random secret Telegram echoes back on every webhook call, so we can verify
# incoming requests genuinely came from Telegram's servers.
TELEGRAM_WEBHOOK_SECRET=

# Site owner's personal Telegram chat id — every feedback submission (from
# the bot or the website) is forwarded here. Get it by messaging @userinfobot.
ADMIN_TELEGRAM_CHAT_ID=

# Password-style code to log into /admin pages (Broadcast, Users, etc.) —
# independent of Telegram/student accounts.
ADMIN_ACCESS_CODE=

# Entering this code (instead of the real Telegram-sent code) in the normal
# Telegram login flow logs in as the shared demo account — for quick demos,
# without affecting real Telegram login for everyone else.
DEMO_LOGIN_CODE=
DEMO_ACCOUNT_EMAIL=

# Google Gemini API key — used to AI-grade Writing test submissions (Task 1 + 2)
# against the official IELTS band descriptors. Free tier, no card needed.
# Get one at aistudio.google.com/apikey.
GEMINI_API_KEY=

# Price of BandPath Pro (30 days) in Telegram Stars. Change this whenever
# ready to set the real price — no code changes needed.
PRO_PRICE_STARS=1
